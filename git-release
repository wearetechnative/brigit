#!/usr/bin/env bash

# git-release - Automated GitHub release script
# Creates semantic version releases with automated VERSION and CHANGELOG.md updates

set -e

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Detect if running in interactive mode
detect_interactive() {
    if [ -t 0 ] && [ -t 1 ]; then
        INTERACTIVE=true
    else
        INTERACTIVE=false
    fi
}

# Show progress indicator
show_progress() {
    local current=$1
    local total=$2
    local message=$3
    echo -ne "${BLUE}[$current/$total]${NC} $message...\r"
}

# Clear progress line
clear_progress() {
    echo -ne "\033[K"
}

# Error message
error() {
    echo -e "${RED}Error:${NC} $1" >&2
}

# Success message
success() {
    echo -e "${GREEN}✓${NC} $1"
}

# Info message
info() {
    echo -e "${BLUE}→${NC} $1"
}

# Show help
show_help() {
    cat << EOF
Usage: git-release [patch|minor|major] [-h]

Create and publish a GitHub release with automated version management.

Arguments:
  patch         Increment patch version (0.0.1 -> 0.0.2)
  minor         Increment minor version (0.0.1 -> 0.1.0)
  major         Increment major version (0.0.1 -> 1.0.0)

Options:
  -h, --help    Show this help message

Examples:
  git-release              # Interactive mode (select version type)
  git-release patch        # Non-interactive (patch release)
  git-release minor        # Minor version release
  git-release major        # Major version release

Requirements:
  - gh (GitHub CLI) must be installed and authenticated
  - gum (for interactive mode) recommended but optional
  - VERSION file in repository root (format: X.Y.Z)
  - CHANGELOG.md file following Keep a Changelog format
  - Clean git working directory (no uncommitted changes)

The script will:
  1. Check git repository is clean
  2. Read current version from VERSION file
  3. Calculate new version based on type
  4. Update VERSION file
  5. Update CHANGELOG.md with version and date
  6. Extract release notes from CHANGELOG.md
  7. Create git commit with changes
  8. Create annotated git tag
  9. Push commit and tag to GitHub
  10. Create GitHub release with release notes
EOF
}

# Main release function
main() {
    local RELEASE_TYPE=""

    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                show_help
                exit 0
                ;;
            patch|minor|major)
                RELEASE_TYPE="$1"
                shift
                ;;
            *)
                error "Unknown argument: $1"
                echo "Use -h or --help for usage information"
                exit 1
                ;;
        esac
    done

    detect_interactive

    # Get release type from argument or interactive prompt
    if [ -z "$RELEASE_TYPE" ]; then
        if $INTERACTIVE && command -v gum &> /dev/null; then
            RELEASE_TYPE=$(gum choose "patch" "minor" "major" --header "Select release type:")
            if [ -z "$RELEASE_TYPE" ]; then
                info "Release cancelled."
                exit 0
            fi
        else
            error "Release type required in non-interactive mode or when gum is not installed."
            echo "Usage: git-release [patch|minor|major]"
            exit 1
        fi
    fi

    # Validate release type
    case "$RELEASE_TYPE" in
        patch|minor|major)
            ;;
        *)
            error "Invalid release type '$RELEASE_TYPE'. Use patch, minor, or major."
            exit 1
            ;;
    esac

    # Check if we're in a git repository
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        error "Not in a git repository"
        exit 1
    fi

    # Get repository root
    REPO_ROOT=$(git rev-parse --show-toplevel)
    cd "$REPO_ROOT"

    # Check if git repository is clean
    local git_status
    git_status=$(git status --porcelain)

    # Filter out untracked files (lines starting with ??)
    local modified_files
    modified_files=$(echo "$git_status" | grep -v "^??" || true)

    if [ -n "$modified_files" ]; then
        error "Git repository is dirty. Commit or stash changes before creating a release."
        echo "$modified_files"
        exit 1
    fi

    # Check for VERSION file
    if [ ! -f "VERSION" ]; then
        error "VERSION file not found in repository root"
        echo "Create a VERSION file with format: X.Y.Z (e.g., 0.0.1)"
        exit 1
    fi

    # Read current version
    local CURRENT_VERSION
    CURRENT_VERSION=$(cat VERSION | tr -d '[:space:]')

    if [ -z "$CURRENT_VERSION" ]; then
        error "VERSION file is empty"
        exit 1
    fi

    # Validate version format
    if ! echo "$CURRENT_VERSION" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
        error "Invalid VERSION file format. Expected X.Y.Z, got: $CURRENT_VERSION"
        exit 1
    fi

    # Calculate new version
    IFS='.' read -r major minor patch <<< "$CURRENT_VERSION"

    case "$RELEASE_TYPE" in
        patch)
            patch=$((patch + 1))
            ;;
        minor)
            minor=$((minor + 1))
            patch=0
            ;;
        major)
            major=$((major + 1))
            minor=0
            patch=0
            ;;
    esac

    local NEW_VERSION="${major}.${minor}.${patch}"

    echo ""
    info "Creating release: v$CURRENT_VERSION → v$NEW_VERSION"
    echo ""

    # Check if tag already exists
    if git tag -l "v${NEW_VERSION}" | grep -q "v${NEW_VERSION}"; then
        error "Tag v${NEW_VERSION} already exists"
        exit 1
    fi

    # Check for CHANGELOG.md
    if [ ! -f "CHANGELOG.md" ]; then
        error "CHANGELOG.md not found in repository root"
        exit 1
    fi

    # Update VERSION file
    show_progress 1 6 "Updating VERSION file"
    echo "$NEW_VERSION" > VERSION
    clear_progress
    success "Updated VERSION file to $NEW_VERSION"

    # Update CHANGELOG.md
    show_progress 2 6 "Updating CHANGELOG.md"
    local RELEASE_DATE
    RELEASE_DATE=$(date +"%Y-%m-%d")

    # Replace first occurrence of [Unreleased] with version and date
    sed -i "0,/## \[Unreleased\]/s//## [${NEW_VERSION}] - ${RELEASE_DATE}/" CHANGELOG.md

    # Add new Unreleased header at the top (after the main title)
    sed -i "/^# Changelog/a\\
\\
## [Unreleased]" CHANGELOG.md

    clear_progress
    success "Updated CHANGELOG.md with version $NEW_VERSION"

    # Extract release notes from CHANGELOG
    show_progress 3 6 "Extracting release notes"
    local NOTES_FILE=$(mktemp)

    # Extract content between the new version header and the next version header
    awk "/## \[${NEW_VERSION}\]/,/## \[[0-9]/" CHANGELOG.md | \
        sed '1d;$d' | \
        sed '/^$/d' > "$NOTES_FILE"

    # If notes file is empty, add a placeholder
    if [ ! -s "$NOTES_FILE" ]; then
        echo "Release v${NEW_VERSION}" > "$NOTES_FILE"
    fi

    clear_progress
    success "Extracted release notes"

    # Commit changes
    show_progress 4 6 "Creating release commit"
    git add VERSION CHANGELOG.md
    git commit -m "Release v${NEW_VERSION}

Co-Authored-By: Claude Sonnet 4.5 <noreply@anthropic.com>"
    clear_progress
    success "Created release commit"

    # Create git tag
    show_progress 5 6 "Creating git tag v${NEW_VERSION}"
    git tag -a "v${NEW_VERSION}" -m "Release v${NEW_VERSION}"
    clear_progress
    success "Created git tag v${NEW_VERSION}"

    # Push to remote
    show_progress 6 6 "Pushing to GitHub"
    if ! git push && git push --tags; then
        error "Failed to push to remote. Tag and commit may need manual cleanup."
        rm -f "$NOTES_FILE"
        exit 1
    fi
    clear_progress
    success "Pushed to GitHub"

    # Create GitHub release
    info "Creating GitHub release..."
    if ! gh release create "v${NEW_VERSION}" --notes-file "$NOTES_FILE"; then
        error "Failed to create GitHub release. Tag is pushed but release creation failed."
        local REPO_PATH=$(git remote get-url origin | sed 's/.*github.com[:/]\(.*\)\.git/\1/')
        echo "You can manually create the release at: https://github.com/${REPO_PATH}/releases/new?tag=v${NEW_VERSION}"
        rm -f "$NOTES_FILE"
        exit 1
    fi

    # Clean up
    rm -f "$NOTES_FILE"

    # Success message
    echo ""
    if $INTERACTIVE && command -v gum &> /dev/null; then
        gum style --foreground 82 --bold "✓ Release v${NEW_VERSION} created successfully!"
    else
        echo -e "${GREEN}✓ Release v${NEW_VERSION} created successfully!${NC}"
    fi

    local REPO_PATH=$(git remote get-url origin | sed 's/.*github.com[:/]\(.*\)\.git/\1/')
    echo "View release: https://github.com/${REPO_PATH}/releases/tag/v${NEW_VERSION}"
    echo ""

    exit 0
}

# Run main function
main "$@"
